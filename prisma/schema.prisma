generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id               String   @id @default(uuid())
  tmdbId           Int?     @unique  // null for Kaggle-sourced entries; set when TMDB ID is known
  title            String
  year             Int
  director         String?
  genres           String   // JSON array of genre name strings
  country          String?
  letterboxdRating Float?
  letterboxdUrl    String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@unique([title, year])  // canonical upsert key across all data sources
}
