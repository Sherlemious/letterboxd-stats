# Neon PostgreSQL — pooled connection (used by the app at runtime)
DATABASE_URL=

# Neon PostgreSQL — direct (non-pooled) connection (used by Prisma migrations only)
# Same as DATABASE_URL but without "-pooler" in the hostname
DIRECT_URL=

# Optional: TMDB API key for on-demand metadata enrichment of uncached films
# Get one at https://www.themoviedb.org/settings/api
# Also used by the ingestion script: TMDB_API_KEY=<key> npm run db:ingest
TMDB_API_KEY=
